rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is admin or manager
    function isHQ() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Manager'];
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Users — anyone logged in can read their own, HQ can read all
    match /users/{uid} {
      allow read: if isOwner(uid) || isHQ();
      allow write: if isOwner(uid) || isHQ();

      // Inbox — only the user or HQ
      match /inbox/{item} {
        allow read, write: if isOwner(uid) || isHQ();
      }

      // Notifications — only the user
      match /notifications/{notif} {
        allow read, write: if isOwner(uid);
      }
    }

    // Workflows — HQ full access, staff read only
    match /workflows/{id} {
      allow read: if request.auth != null;
      allow write: if isHQ();
    }

    // Tasks — HQ full access, staff read only
    match /tasks/{id} {
      allow read: if request.auth != null;
      allow write: if isHQ();
    }

    // Forms — HQ full access
    match /forms/{id} {
      allow read: if request.auth != null;
      allow write: if isHQ();
    }

    // Cases — HQ full access, staff read own
    match /cases/{id} {
      allow read: if request.auth != null;
      allow write: if isHQ();
    }

    // Requests — staff can create, HQ can read/update all
    match /requests/{id} {
      allow create: if request.auth != null;
      allow read: if isHQ() || resource.data.submittedBy == request.auth.uid;
      allow update: if isHQ();
    }

    // Invites — HQ can create, anyone with token can read
    match /invites/{token} {
      allow read: if true; // verified by Cloud Function
      allow write: if isHQ();
    }

    // Org settings — HQ only
    match /settings/{id} {
      allow read: if request.auth != null;
      allow write: if isHQ();
    }
  }
}
